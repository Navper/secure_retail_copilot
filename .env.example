# Secure Retail AI Copilot — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# ⚠️ NUNCA pongas claves reales aquí — este archivo SÍ se sube a git.

# Clave de API de Google Gemini (obligatoria)
GOOGLE_API_KEY=

# ───────────────────────────────────────
# Autenticación del panel de administración
# ───────────────────────────────────────
# Opción A (RECOMENDADA): Contraseña en hash SHA256
# Para generar el hash de tu contraseña, ejecuta:
#   python -c "from auth import hash_password; print(hash_password('tu_password_segura'))"
# y pega el resultado aquí:
ADMIN_PASSWORD_HASH=

# Salt usado en el hashing. Cámbialo por un valor único en tu instalación.
PASSWORD_SALT=secure_retail_default_salt_v1

# Opción B (FALLBACK — menos seguro): Contraseña en texto plano
# Solo si no configuras ADMIN_PASSWORD_HASH. Muestra aviso en consola.
ADMIN_PASSWORD=admin123

# ───────────────────────────────────────
# Seguridad (Fase 2)
# ───────────────────────────────────────
# Máximo de mensajes permitidos por sesión por minuto
RATE_LIMIT_PER_MINUTE=15

# Umbral de confianza mínimo para bloquear un input (0.0 – 1.0)
# Más bajo = más estricto (más falsos positivos)
# Más alto = más permisivo (más falsos negativos)
SECURITY_CONFIDENCE_THRESHOLD=0.6

# Longitud máxima de input en caracteres (evita DoS por coste de API)
MAX_INPUT_LENGTH=2000
