# Secure Retail AI Copilot — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# ⚠️ NUNCA pongas claves reales aquí — este archivo SÍ se sube a git.

# Clave de API de Google Gemini (obligatoria)
GOOGLE_API_KEY=

# Contraseña del panel de administración
ADMIN_PASSWORD=admin123

# ───────────────────────────────────────
# Seguridad (Fase 2)
# ───────────────────────────────────────
# Máximo de mensajes permitidos por sesión por minuto
RATE_LIMIT_PER_MINUTE=15

# Umbral de confianza mínimo para bloquear un input (0.0 – 1.0)
# Más bajo = más estricto (más falsos positivos)
# Más alto = más permisivo (más falsos negativos)
SECURITY_CONFIDENCE_THRESHOLD=0.6
